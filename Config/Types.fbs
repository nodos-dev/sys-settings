namespace nos.sys.settings;

attribute "dynamic";
attribute "key";

table SettingsEntry{
    entry_name: string (key);
    type_name: string;
    data: [ubyte] (dynamic: "type_name");
}

table ModuleSettings{
    module_name:string;
    module_version:string;
    settings: [SettingsEntry];
}

table ModuleSettingsList{
    module_settings: [ModuleSettings];
}